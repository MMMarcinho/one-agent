{
  "name": "one-agent",
  "version": "0.1.0",
  "description": "One entrypoint to drive and orchestrate any local coding agent (Claude Code, Codex, and any ACP-compatible agent).",
  "type": "module",
  "bin": {
    "one-agent": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./adapters": "./dist/adapters/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx ./test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
