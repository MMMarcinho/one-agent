{
  "name": "one-agent",
  "version": "0.1.0",
  "description": "One entrypoint to drive and orchestrate any local coding agent (Claude Code, Codex, and any ACP-compatible agent).",
  "type": "module",
  "main": "dist/desktop/main/index.js",
  "bin": {
    "one-agent": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./app": "./dist/app.js",
    "./adapters": "./dist/adapters/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:renderer": "vite build -c desktop/vite.config.ts",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:renderer": "tsc -p desktop/renderer/tsconfig.json --noEmit",
    "desktop:build": "npm run build && npm run build:renderer",
    "desktop:dev": "cross-env ONE_AGENT_DEV=1 concurrently -k -n vite,electron \"vite -c desktop/vite.config.ts\" \"npm run desktop:electron\"",
    "desktop:electron": "npm run build && wait-on tcp:5173 && electron .",
    "desktop:start": "npm run desktop:build && electron .",
    "dist:mac": "npm run desktop:build && electron-builder --mac",
    "test": "node --test --import tsx ./test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.oneagent.desktop",
    "productName": "one-agent",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    }
  }
}
